# Base de datos PostgreSQL (Neon.tech o Render)
DATABASE_URL=postgresql://usuario:password@host/database?sslmode=require

# Seguridad JWT (generar SECRET_KEY segura: openssl rand -hex 32)
SECRET_KEY=tu_clave_secreta_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Servidor
PORT=8002

# CORS: orígenes permitidos separados por coma (frontend React/Vite)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
